{
  "name": "pscv-room-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run cf:dev:remote",
    "next:dev": "next dev",
    "build": "next build",
    "smoke": "node scripts/smoke.mjs",
    "start": "wrangler dev --port 8788",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dev": "npm run cf:build && wrangler dev --port 8788",
    "cf:dev:remote": "npm run cf:build && wrangler dev --remote --port 8788",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:deploy:staging": "npm run cf:build && wrangler deploy --env staging",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "jose": "^6.1.3",
    "lucide-react": "^1.18.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "typescript": "^5.6.0",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
