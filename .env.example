# PostgreSQL direct connection, optional. Para server jobs/migraciones.
DATABASE_URL=""

# Cloudflare R2 / S3 compatible storage.
# Endpoint privado S3-compatible para upload/signing:
# https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""

# Dominio público del bucket R2. Usar un host dedicado, por ejemplo:
# https://assets.rlead.xyz
# No uses el mismo host de la app si Vercel/Next también sirve ese dominio.
CLOUDFLARE_R2_PUBLIC_BASE_URL=""
# Alternativa equivalente si prefieres guardar solo el dominio:
CLOUDFLARE_R2_PUBLIC_DOMAIN=""

# Google Sheets legacy migration, optional
GOOGLE_SHEETS_SPREADSHEET_ID=""
