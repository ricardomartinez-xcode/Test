# App
NEXT_PUBLIC_APP_NAME="PSCV Room 2.0"
NEXT_PUBLIC_APP_URL="http://localhost:8788"

# Cloudflare deploy/local tooling. Keep real values out of git.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Cloudflare Access + Microsoft Entra ID.
# In production, AUTH_MODE is set in wrangler.jsonc as cloudflare-access.
ACCESS_TEAM_DOMAIN=""
ACCESS_AUD=""

# Local development only, for wrangler dev --remote without an Access session.
AUTH_MODE="development"
ALLOW_DEV_AUTH="1"
DEV_AUTH_EMAIL="admin@example.com"

# Cloudflare R2 binding in wrangler.jsonc:
# MATERIALS_BUCKET -> bucket psicologia
#
# Public base for generated material URLs. Optional; without it the Worker
# streams files through /api/materials/<id>/file using the R2 binding.
R2_PUBLIC_BASE_URL=""

# Transactional email for announcements. Optional; without these, notices remain in-app only.
RESEND_API_KEY=""
EMAIL_FROM="PSCV Room <avisos@example.com>"

# Legacy Sheets migration flag. Optional.
GOOGLE_SHEETS_SPREADSHEET_ID=""
